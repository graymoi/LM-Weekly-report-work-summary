# Git 忽略文件配置

# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# IDE 配置文件
.vscode/
.idea/
*.swp
*.swo
*~

# 临时文件
*.tmp
*.temp
*.log
*.bak

# 输出文件（保留结构，忽略内容）
输出成果/**/*
!输出成果/.gitkeep
输出成果/日总结/**/*
!输出成果/日总结/.gitkeep
输出成果/周工作总结/**/*
!输出成果/周工作总结/.gitkeep
输出成果/新闻监测记录/**/*
!输出成果/新闻监测记录/.gitkeep
输出成果/深度研究/**/*
!输出成果/深度研究/.gitkeep
输出成果/任务编排/**/*
!输出成果/任务编排/.gitkeep
输出成果/任务编排/temp/**/*
!输出成果/任务编排/temp/.gitkeep
输出成果/知识增强/**/*
!输出成果/知识增强/.gitkeep
输出成果/自我优化/**/*
!输出成果/自我优化/.gitkeep
输出成果/归档/**/*
!输出成果/归档/.gitkeep

# 工作记录（用户输入，AI只读）
工作记录/**/*
!工作记录/.gitkeep

# 项目库（半自动，用户核查）
项目库/**/*
!项目库/.gitkeep
!项目库/项目跟踪记录.md
!项目库/_项目知识/.gitkeep

# 个人知识库（AI自动维护）
个人知识库/**/*
!个人知识库/.gitkeep

# 敏感信息
*.env
.env.local
.env.*.local
*.key
*.pem
credentials.json

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 临时工作文件夹
临时工作文件夹/**/*
!临时工作文件夹/.gitkeep

# 新闻监测历史
.trae/skills/新闻监测/history.json

# 优化临时文件
.trae/skills/任务编排/temp/**/*
!.trae/skills/任务编排/temp/.gitkeep
